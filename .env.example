# PraxisNova Website – Umgebungsvariablen
# Kopiere diese Datei als .env.local und fülle die Werte aus
# Alle Werte auch in Vercel unter Settings > Environment Variables eintragen

# HubSpot CRM (Lead-Erfassung)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# Brevo (E-Mail Marketing)
BREVO_API_KEY=
BREVO_LIST_ID=

# Webhook Secret (Verbindung zum Sales Control Center)
INBOUND_WEBHOOK_SECRET=

# Öffentliche URLs
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/meyer-samantha-praxisnovaai/erstgesprach
NEXT_PUBLIC_SITE_URL=https://www.praxisnovaai.com
